# Dependencies
node_modules/

# Generated by npm run build:libs (WASM, cloned libraries, fonts; regenerate on each machine)
libs/

# Webpack / production output
dist/
build/

# Library bundles and WASM links produced by build:libs
public/libraries/*.zip
public/openscad.js
public/openscad.wasm

# Symlink or junction from build:libs → libs/openscad-wasm
src/wasm

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tests / coverage
coverage/
.nyc_output/

# TypeScript incremental
*.tsbuildinfo

# Environment (local secrets; do not commit)
.env
.env.local
.env.*.local

# Docker
backend-data/

# Backend runtime data (encryption keys, encrypted API keys)
backend/data/*
!backend/data/.gitkeep

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE (local)
.idea/
*.iml
*.swp
*~

# Optional local scratch
*.local
