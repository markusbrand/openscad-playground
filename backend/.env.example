# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://openscad.brandstaetter.rocks

# Master prompt
MASTER_PROMPT_PATH=prompts/master-prompt.md

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# API Keys — this file lives next to the backend app: backend/.env (loaded even if you start uvicorn from another cwd).
# Values here override keys previously saved in the app UI (backend/data/api_keys.json).
# Gemini: use a key from Google AI Studio (https://aistudio.google.com/apikey), not a GCP service account.
# One line, no quotes, no spaces around '=': GEMINI_API_KEY=AIza...
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=

# Auto-debug
MAX_AUTODEBUG_RETRIES=3

# Logging
LOG_LEVEL=INFO
