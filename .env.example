# ============================================================
# OpenSCAD Playground — Root `.env` (Repository-Hauptverzeichnis)
# Kopieren nach `.env` und Werte setzen.
# ============================================================
#
# Ladereihenfolge (wichtig):
#   • FastAPI lädt zuerst diese Datei, danach `backend/.env` — bei gleichem
#     Variablennamen gewinnt `backend/.env`.
#   • Vite (`npm run dev`, Playwright) merged Root-`.env` + `backend/.env`
#     — ebenfalls gewinnt `backend/.env` bei Duplikaten.
#   • `docker compose` liest nur diese Root-`.env` (`env_file: .env` beim
#     Backend-Container). `backend/.env` wird vom Compose-Setup nicht
#     automatisch eingebunden — für reine Docker-Nutzung müssen alle
#     Backend-Variablen daher hier stehen.
#
# Redundanz vermeiden:
#   • Ports: nur hier definieren (nicht noch einmal in `backend/.env`,
#     außer du willst explizit andere Werte für lokalen `uvicorn`).
#   • CORS / Ollama / API-Keys: entweder nur hier (typisch: Docker) **oder**
#     nur in `backend/.env` (typisch: lokales `python dev.py` + Vite) —
#     nicht dieselben Keys widersprüchlich in beiden Dateien pflegen.
#     Details: `backend/.env.example`
# ============================================================

# --- Primär hier: Ports (Docker + Vite) ---
FRONTEND_PORT=3080
# Im Docker-Stack muss das zum Upstream in nginx.conf passen (Frontend → backend:8000). Nicht ändern, außer du passt nginx an.
BACKEND_PORT=8000
FRONTEND_DEV_PORT=5173

# --- Docker-Images (GHCR) ---
# CI pusht nach ghcr.io/<github-owner>/<repo-klein>/backend|frontend (Tags: latest, <git-sha>).
# Standard unten = dieses Upstream-Repo; bei Fork eigenen Pfad setzen oder PAT + docker login ghcr.io.
# IMAGE_TAG=latest
# Oder pin auf Release: z. B. 1.2.3 / v1.2.3 (nach Git-Tag v1.2.3 auf main), oder voller Git-SHA aus GHCR.
# BACKEND_IMAGE=ghcr.io/markusbrand/openscad-playground/backend
# FRONTEND_IMAGE=ghcr.io/markusbrand/openscad-playground/frontend

# --- Backend (Compose / gemeinsame Defaults) ---
# Für `docker compose` nötig, weil nur diese `.env` in den Backend-Container geht.
# Wenn du alles unter `backend/.env` pflegst: diese Blöcke hier weglassen oder
# nur Werte eintragen, die speziell für Docker gelten sollen.

CORS_ALLOWED_ORIGINS=http://localhost:3080,https://openscad.brandstaetter.rocks
MASTER_PROMPT_PATH=prompts/master-prompt.md
OLLAMA_BASE_URL=http://host.docker.internal:11434

# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=

MAX_AUTODEBUG_RETRIES=3
LOG_LEVEL=INFO
