# ============================================================
# OpenSCAD Playground - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Ports ---
# Docker Compose: host port for the frontend container (nginx on :80 inside).
FRONTEND_PORT=3080
# FastAPI listen port inside the backend container (and healthcheck). Default 8000.
BACKEND_PORT=8000
# Vite dev server (npm run dev). Vite reads repo root + backend/.env (backend wins).
FRONTEND_DEV_PORT=5173

# --- Backend ---
# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3080,https://openscad.brandstaetter.rocks

# Master prompt path (relative to backend/)
MASTER_PROMPT_PATH=prompts/master-prompt.md

# Ollama (local LLM) endpoint
OLLAMA_BASE_URL=http://host.docker.internal:11434

# LLM API Keys (alternatively configure via the UI)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=

# Auto-debug max retries
MAX_AUTODEBUG_RETRIES=3

# Logging
LOG_LEVEL=INFO
