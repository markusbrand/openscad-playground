{
  "name": "openscad-playground",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://ochafik.com/openscad2/",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "@monaco-editor/loader": "^1.4.0",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "blurhash": "^2.0.5",
    "chroma-js": "^3.1.2",
    "debug": "^4.4.0",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "thumbhash": "^0.1.1",
    "uuid": "^11.0.3",
    "uzip": "^0.20201231.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd backend && .venv/bin/python dev.py",
    "build": "vite build",
    "preview": "vite preview",
    "build:libs": "cross-env LIBS_BUILD_MODE=all webpack --config webpack.libs.config.js",
    "build:libs:clean": "cross-env LIBS_BUILD_MODE=clean webpack --config webpack.libs.config.js",
    "build:libs:wasm": "cross-env LIBS_BUILD_MODE=wasm webpack --config webpack.libs.config.js",
    "build:libs:fonts": "cross-env LIBS_BUILD_MODE=fonts webpack --config webpack.libs.config.js",
    "build:all": "npm run build:libs && npm run build",
    "start:development": "vite --host 127.0.0.1 --port 4000 --strictPort",
    "start:production": "vite preview --host 127.0.0.1 --port 3000 --strictPort",
    "start:test": "vite --host 127.0.0.1 --port 4000 --strictPort",
    "test:e2e": "playwright test"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "devDependencies": {
    "@types/chroma-js": "^2.4.5",
    "@types/debug": "^4.1.12",
    "@types/filesystem": "^0.0.36",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uzip": "^0.20201231.2",
    "@types/web": "^0.0.140",
    "@vitejs/plugin-react": "^4.3.0",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "glob": "^11.0.0",
    "livereload": "^0.9.3",
    "serve": "^14.2.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^2.2.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "workbox-webpack-plugin": "^7.3.0"
  }
}
